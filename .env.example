# ─── DownloadHub Pro — docker-compose environment ───
# Copy to .env and edit the values, then run:  docker compose up -d --build

# PostgreSQL credentials (used by the db, backend services)
POSTGRES_USER=downloadhub
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=downloadhub

# Auth — REQUIRED. Generate with:  openssl rand -base64 48
JWT_SECRET=
SESSION_DAYS=30

# Cookies: set to "true" ONLY when serving over HTTPS (see DEPLOY.md).
# Leave "false" for plain-HTTP testing or the login cookie won't be sent.
COOKIE_SECURE=false

# CORS: the public origin of the site. "*" reflects the request origin and
# works for same-origin Nginx setups. Set to https://yourdomain.com in prod.
CORS_ORIGIN=*

# Public web port (the Nginx container). Use 80 for HTTP, or front it with a TLS proxy.
WEB_PORT=80

# ─── yt-dlp network ───
YTDLP_GEO_BYPASS=true
YTDLP_GEO_BYPASS_COUNTRY=
YTDLP_PROXY=
YTDLP_COOKIES=
YTDLP_TIMEOUT=60
YTDLP_RETRIES=5
YTDLP_CONCURRENT=2

# ─── VPN / geo-unlock framework ───
# Provider: auto | surfshark | nordvpn | protonvpn | mullvad | pia | expressvpn |
#           http-proxy | socks5-proxy | wireguard | openvpn | tailscale | none
VPN_PROVIDER=auto
VPN_COUNTRY=BD
AUTO_RECONNECT=true
VERIFY_PUBLIC_IP=true
# Host VPN local proxy exposed to Docker backend (e.g. socks5://host.docker.internal:1080)
VPN_LOCAL_PROXY_URL=

# Commercial VPN credentials (set only what you use — never commit real values)
# SURFSHARK_USER= SURFSHARK_PASSWORD=
# NORDVPN_TOKEN=
# PROTONVPN_USER= PROTONVPN_PASSWORD=
# MULLVAD_ACCOUNT=
# PIA_USER= PIA_PASSWORD=
# EXPRESSVPN_ACTIVATION_CODE=

# Bangladesh / custom tunnel configs (paths on VPS host)
# TAILSCALE_AUTH_KEY= TAILSCALE_EXIT_NODE= TAILSCALE_EXIT_NODE_BD=
# CUSTOM_WG_BD_CONFIG=/etc/wireguard/bd.conf
# CUSTOM_OVPN_BD_CONFIG=/etc/openvpn/bd.ovpn
# WG_CONFIG_PATH= OPENVPN_CONFIG_DIR=
