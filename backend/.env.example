# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
# Local dev points at the docker-compose "db" service mapped to localhost:5432
DATABASE_URL=postgresql://downloadhub:downloadhub@localhost:5432/downloadhub?schema=public

# Auth
# Generate a strong secret in production: openssl rand -base64 48
JWT_SECRET=dev-insecure-secret-change-me
SESSION_DAYS=30
# Force secure cookies (https only). Auto-enabled when NODE_ENV=production.
COOKIE_SECURE=false

# Python / yt-dlp
# Command used to invoke yt-dlp. We call it as a module: `<PYTHON_BIN> -m yt_dlp`
PYTHON_BIN=python

# Geo-restriction handling
# Spoof X-Forwarded-For to bypass region locks (works for many sites). Default on.
YTDLP_GEO_BYPASS=true
# Force a country for the spoofed header, e.g. US, GB, DE. Leave blank for auto.
YTDLP_GEO_BYPASS_COUNTRY=
# Route yt-dlp through a proxy. REQUIRED for hard YouTube geo-blocks
# ("not available in your country"), since YouTube ignores X-Forwarded-For.
# Example: http://user:pass@host:port  or  socks5://host:port
YTDLP_PROXY=
# Path (inside the container) to a Netscape cookies.txt for login/age/region-gated media.
YTDLP_COOKIES=

# yt-dlp performance
YTDLP_TIMEOUT=60
YTDLP_RETRIES=5
YTDLP_CONCURRENT=2

# VPN geo-unlock framework (see ops/README.md)
VPN_PROVIDER=auto
VPN_COUNTRY=BD
AUTO_RECONNECT=true
VERIFY_PUBLIC_IP=false
VPN_LOCAL_PROXY_URL=

GUEST_DOWNLOADS_PER_DAY=10
